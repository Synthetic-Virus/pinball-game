# Godot 4
# Import cache: always regenerated on open, never committed.
.godot/
/build/
/export/

# Vendored addon import sidecars (addons/gut/...). Godot rewrites these .import/.uid files when it
# re-imports the addon's bundled assets (fonts, icons), and different Godot point releases add new
# keys, so they CHURN the tree on every headless run. They are pure regenerated cache for VENDORED
# assets (not our own scenes/scripts), so we ignore them. NOTE: this is scoped to addons/ ONLY - the
# .import/.uid sidecars for our REAL project assets (scenes/, scripts/, tests/) ARE tracked, per
# Godot 4.x practice, because they carry stable resource IDs the project references.
addons/**/*.import
addons/**/*.uid

# Local dev tooling - not part of the public game source.
.claude/
docs/TEAM.md

# Build outputs
*.exe
*.pck
*.zip
*.app
*.dmg
*.x86_64

# Runner / CI local env
ci/runner/.env

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/

# Internal docs kept local, not in the public repo (screenshots stay for the README):
docs/*
!docs/screenshots/

# Test suite kept local, not in the public repo:
tests/
