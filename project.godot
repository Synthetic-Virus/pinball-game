; Godot 4 project file. Working title - rename config/name freely.
config_version=5

[application]
config/name="Pinball (working title)"
run/main_scene="res://scenes/Table.tscn"
config/description="A pinball game targeting a commercial Steam release. Built by a team of specialized agents (docs/TEAM.md). Built on the homelab, deployed by git push (docs/INFRA.md)."
config/features=PackedStringArray("4.6")

[autoload]
; TableConfig is the SINGLE SOURCE OF TRUTH for world scale (ball radius, playfield extents,
; flipper length, gravity, tilt). Every element reads from it; nobody hardcodes a competing scale.
; PhysicsLayers names the four collision layers so code never uses raw bit numbers.
; Both are read-only contracts owned by the lead-programmer. See docs/ARCHITECTURE.md.
TableConfig="*res://scripts/config/table_config.gd"
PhysicsLayers="*res://scripts/config/physics_layers.gd"

[display]
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"

[input]
; ACTION-BASED INPUT (pinhead pattern). Code reads actions, never raw keys, so remap is cheap later.
; Defaults: left flipper = A / Left-Arrow, right flipper = D / Right-Arrow, launch = Space,
; nudge = Up-Arrow / W. One nudge action this slice; left/right nudge are deferred (DESIGN cut list).
left_flipper={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":65,"key_label":0,"unicode":97,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194319,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
right_flipper={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":68,"key_label":0,"unicode":100,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194321,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
launch={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":32,"key_label":0,"unicode":32,"location":0,"echo":false,"script":null)
]
}
nudge={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194320,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
, Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":87,"key_label":0,"unicode":119,"location":0,"echo":false,"script":null)
]
}

[layer_names]
; Four physics layers (pinhead pattern). Bit 1 Playfield, bit 2 Static Obstacles,
; bit 3 Kinematic Obstacles, bit 4 Balls. Names mirror scripts/config/physics_layers.gd;
; keep the two in sync. Code uses PhysicsLayers.* constants, never raw bits.
3d_physics/layer_1="Playfield"
3d_physics/layer_2="StaticObstacles"
3d_physics/layer_3="KinematicObstacles"
3d_physics/layer_4="Balls"

[physics]
; Pinball is physics-first. Modern foundation: built-in Jolt physics (Godot 4.4+), a high 240 Hz
; tick, and Jolt CCD/sleep/solver tuning adopted from the MIT-licensed pinhead reference.
; continuous_cd on the ball is still set in code. See .claude/CLAUDE.md.
; default_gravity raised 9.8 -> 200 for the larger pinhead-style world scale (see docs/ARCHITECTURE.md
; and TableConfig). Strong gravity at a tens-of-units scale is what the force-driven flipper tuning
; is calibrated for and keeps Jolt's solver well behaved.
common/physics_ticks_per_second=240
common/max_physics_steps_per_frame=32
3d/physics_engine="Jolt Physics"
3d/default_gravity=200.0
jolt_3d/sleep/velocity_threshold=0.002
jolt_3d/continuous_cd/max_penetration=0.0
jolt_3d/solver/bounce_velocity_threshold=10.0
