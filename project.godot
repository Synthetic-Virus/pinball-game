; Godot 4 project file. Working title - rename config/name freely.
config_version=5

[application]
config/name="Pinball (working title)"
run/main_scene="res://scenes/Main.tscn"
config/description="A pinball game targeting a commercial Steam release. Built by a team of specialized agents (docs/TEAM.md). Built on the homelab, deployed by git push (docs/INFRA.md)."
config/features=PackedStringArray("4.6")

[display]
window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="canvas_items"

[physics]
; Pinball is physics-first. Modern foundation: built-in Jolt physics (Godot 4.4+), a high 240 Hz
; tick, and Jolt CCD/sleep/solver tuning adopted from the MIT-licensed pinhead reference.
; continuous_cd on the ball is still set in code. See .claude/CLAUDE.md.
common/physics_ticks_per_second=240
common/max_physics_steps_per_frame=32
3d/physics_engine="Jolt Physics"
3d/default_gravity=9.8
jolt_3d/sleep/velocity_threshold=0.002
jolt_3d/continuous_cd/max_penetration=0.0
jolt_3d/solver/bounce_velocity_threshold=10.0
