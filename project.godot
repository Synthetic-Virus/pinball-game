[layer_names]

3d_physics/layer_1="Playfield"
3d_physics/layer_2="StaticObstacles"
3d_physics/layer_3="KinematicObstacles"
3d_physics/layer_4="Balls"

[input_devices]

; Touch on a button emulates a mouse click, so on-screen buttons (menu, editor) stay tappable on a
; touchscreen. The play-area flipper touch controls read raw screen touches in layout_editor.gd.
pointing/emulate_mouse_from_touch=true

[physics]

common/physics_ticks_per_second=240
common/max_physics_steps_per_frame=32
3d/physics_engine="Jolt Physics"
3d/default_gravity=200.0
jolt_3d/sleep/velocity_threshold=0.002
jolt_3d/continuous_cd/max_penetration=0.0
jolt_3d/solver/bounce_velocity_threshold=10.0
